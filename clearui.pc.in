prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: ClearUI
Description: Immediate-mode GUI library with software rendering
Version: @PROJECT_VERSION@
Cflags: -I${includedir}
Libs: -L${libdir} -lclearui -lm
